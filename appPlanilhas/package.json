{
  "name": "planilha-sync-server",
  "version": "1.0.0",
  "description": "Servidor de sincronização para o Planilha Offline v4",
  "main": "server.js",
  "scripts": {
    "build": "node -e \"require('fs').writeFileSync('version.json', JSON.stringify({version: (process.env.NIXPACKS_GIT_SHA || process.env.COMMIT_SHA || process.env.GIT_COMMIT_SHA || 'sem-git').substring(0,7)}))\"",
    "start": "node server.js"
  },
  "dependencies": {
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.19.2",
    "multer": "^1.4.5-lts.1",
    "pg": "^8.11.5"
  }
}
